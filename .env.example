# Configurações Gerais
PROJECT_NAME=JanjIA
ENV=development

# Backend FastAPI
PORT=8000
SECRET_KEY=sua_chave_secreta_super_segura_e_longa_aqui_123456789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Inicial Admin (Criado automaticamente se não existir)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@janjia.com
ADMIN_PASSWORD=admin_senha_secreta_123

# Banco de Dados PostgreSQL
POSTGRES_SERVER=postgres
POSTGRES_USER=janjia_user
POSTGRES_PASSWORD=janjia_password
POSTGRES_DB=janjia_db
POSTGRES_PORT=5432

# Cache Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Ollama LLM
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=60
OLLAMA_MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
